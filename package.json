{
  "name": "price-monitoring-agent",
  "version": "1.0.2",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "web:dev": "pnpm --filter @price-monitor/web dev",
    "mcp:dev": "bash scripts/dev-mcp.sh",
    "mcp:build": "pnpm --filter @price-monitor/mcp-server build",
    "mcp:up": "docker compose --profile mcp up -d --build mcp-server",
    "mcp:down": "docker compose stop mcp-server",
    "mcp:logs": "docker compose logs -f mcp-server",
    "mcp:restart": "docker compose --profile mcp restart mcp-server",
    "worker:dev": "bash scripts/dev-worker.sh",
    "worker:up": "docker compose --profile worker up -d --build worker",
    "worker:down": "docker compose stop worker",
    "worker:logs": "docker compose logs -f worker",
    "worker:restart": "docker compose --profile worker restart worker",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "redeploy:coolify": "node scripts/redeploy-local.js",
    "lint": "biome lint .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "docker:ps": "docker compose ps",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "!apps/dashboard_template",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "dotenv": "^16.6.1"
  }
}
